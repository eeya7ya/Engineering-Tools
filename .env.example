# ─── Neon PostgreSQL ────────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── Google OAuth ────────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Set Authorized JavaScript origins: http://localhost:3000
# Set Authorized redirect URIs: http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── JWT Secret ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
JWT_SECRET=replace-with-a-random-40-plus-character-secret-string

# ─── Server ─────────────────────────────────────────────────────────────
PORT=3000
